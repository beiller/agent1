# Default configuration for agent1
# Copy this file to .env and modify as needed

# Llama server base URL (default: http://127.0.0.1:8080)
LLAMA_BASE_URL=http://127.0.0.1:8080

# Current model name (optional, used for initial load)
CURRENT_MODEL=Qwen_Qwen3.5-27B-Q4_K_M.gguf

# Llama server binary path
LLAMA_SERVER_PATH=./llama.cpp/build/bin/llama-server

# Llama models directory
LLAMA_MODELS_DIR=./models

# Discord Bot Token
DISCORD_TOKEN="discord token here"
